{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environment": {
      "type": "string",
      "allowedValues": ["dev", "prod"],
      "metadata": { "description": "Deployment environment (dev or prod)" }
    },
    "appNamePrefix": {
      "type": "string",
      "defaultValue": "finflow",
      "metadata": { "description": "Base name prefix for all resources" }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": { "description": "Azure region for all resources" }
    },
    "appServicePlanSku": {
      "type": "string",
      "defaultValue": "B1",
      "allowedValues": ["F1", "B1", "B2"],
      "metadata": { "description": "App Service Plan SKU (F1=Free, B1=Basic ~$13/mo)" }
    },
    "sqlDatabaseTier": {
      "type": "string",
      "defaultValue": "Basic",
      "allowedValues": ["Serverless", "Basic"],
      "metadata": { "description": "SQL Database tier (Serverless=auto-pause/cheap for dev, Basic=5DTU for prod)" }
    },
    "sqlAdminLogin": {
      "type": "string",
      "defaultValue": "finflowadmin",
      "metadata": { "description": "SQL Server administrator login name" }
    },
    "sqlAdminPassword": {
      "type": "securestring",
      "metadata": { "description": "SQL Server administrator password" }
    },
    "jwtKey": {
      "type": "securestring",
      "metadata": { "description": "JWT signing key (32+ characters)" }
    },
    "smtpHost": {
      "type": "string",
      "defaultValue": "",
      "metadata": { "description": "SMTP server host (leave empty to disable email)" }
    },
    "smtpPort": {
      "type": "string",
      "defaultValue": "587",
      "metadata": { "description": "SMTP server port" }
    },
    "smtpEnableSsl": {
      "type": "string",
      "defaultValue": "true",
      "metadata": { "description": "SMTP enable SSL" }
    },
    "smtpUsername": {
      "type": "string",
      "defaultValue": "",
      "metadata": { "description": "SMTP username" }
    },
    "smtpPassword": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": { "description": "SMTP password" }
    },
    "smtpFromAddress": {
      "type": "string",
      "defaultValue": "",
      "metadata": { "description": "SMTP from email address" }
    },
    "smtpFromName": {
      "type": "string",
      "defaultValue": "FinFlow",
      "metadata": { "description": "SMTP from display name" }
    }
  },
  "variables": {
    "uniqueSuffix": "[toLower(substring(uniqueString(resourceGroup().id), 0, 6))]",
    "appServicePlanName": "[concat(parameters('appNamePrefix'), '-', parameters('environment'), '-plan')]",
    "webAppName": "[concat(parameters('appNamePrefix'), '-', parameters('environment'), '-', variables('uniqueSuffix'))]",
    "sqlServerName": "[concat(parameters('appNamePrefix'), '-', parameters('environment'), '-sql-', variables('uniqueSuffix'))]",
    "databaseName": "[concat('FinFlow-', parameters('environment'))]",
    "aspnetcoreEnvironment": "[if(equals(parameters('environment'), 'prod'), 'Production', 'Development')]",
    "sqlConnectionString": "[concat('Server=tcp:', variables('sqlServerName'), '.database.windows.net,1433;Initial Catalog=', variables('databaseName'), ';Persist Security Info=False;User ID=', parameters('sqlAdminLogin'), ';Password=', parameters('sqlAdminPassword'), ';MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;')]",
    "webAppUrl": "[concat('https://', variables('webAppName'), '.azurewebsites.net')]",
    "isServerless": "[equals(parameters('sqlDatabaseTier'), 'Serverless')]"
  },
  "resources": [
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2022-03-01",
      "name": "[variables('appServicePlanName')]",
      "location": "[parameters('location')]",
      "kind": "linux",
      "sku": {
        "name": "[parameters('appServicePlanSku')]"
      },
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2022-03-01",
      "name": "[variables('webAppName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]"
      ],
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "DOTNETCORE|8.0",
          "alwaysOn": "[not(equals(parameters('appServicePlanSku'), 'F1'))]",
          "ftpsState": "Disabled",
          "minTlsVersion": "1.2",
          "appSettings": [
            {
              "name": "ASPNETCORE_ENVIRONMENT",
              "value": "[variables('aspnetcoreEnvironment')]"
            },
            {
              "name": "ASPNETCORE_URLS",
              "value": "http://0.0.0.0:8080"
            },
            {
              "name": "WEBSITES_PORT",
              "value": "8080"
            },
            {
              "name": "ConnectionStrings__DefaultConnection",
              "value": "[variables('sqlConnectionString')]"
            },
            {
              "name": "Jwt__Key",
              "value": "[parameters('jwtKey')]"
            },
            {
              "name": "Jwt__Issuer",
              "value": "FinFlowApi"
            },
            {
              "name": "Jwt__Audience",
              "value": "FinFlowClient"
            },
            {
              "name": "Jwt__ExpiryHours",
              "value": "24"
            },
            {
              "name": "Cors__AllowedOrigins__0",
              "value": "[variables('webAppUrl')]"
            },
            {
              "name": "Smtp__Host",
              "value": "[parameters('smtpHost')]"
            },
            {
              "name": "Smtp__Port",
              "value": "[parameters('smtpPort')]"
            },
            {
              "name": "Smtp__EnableSsl",
              "value": "[parameters('smtpEnableSsl')]"
            },
            {
              "name": "Smtp__Username",
              "value": "[parameters('smtpUsername')]"
            },
            {
              "name": "Smtp__Password",
              "value": "[parameters('smtpPassword')]"
            },
            {
              "name": "Smtp__FromAddress",
              "value": "[parameters('smtpFromAddress')]"
            },
            {
              "name": "Smtp__FromName",
              "value": "[parameters('smtpFromName')]"
            }
          ]
        }
      }
    },
    {
      "type": "Microsoft.Sql/servers",
      "apiVersion": "2022-05-01-preview",
      "name": "[variables('sqlServerName')]",
      "location": "[parameters('location')]",
      "properties": {
        "administratorLogin": "[parameters('sqlAdminLogin')]",
        "administratorLoginPassword": "[parameters('sqlAdminPassword')]",
        "version": "12.0",
        "minimalTlsVersion": "1.2",
        "publicNetworkAccess": "Enabled"
      },
      "resources": [
        {
          "type": "firewallRules",
          "apiVersion": "2022-05-01-preview",
          "name": "AllowAzureServices",
          "dependsOn": [
            "[resourceId('Microsoft.Sql/servers', variables('sqlServerName'))]"
          ],
          "properties": {
            "startIpAddress": "0.0.0.0",
            "endIpAddress": "0.0.0.0"
          }
        }
      ]
    },
    {
      "type": "Microsoft.Sql/servers/databases",
      "apiVersion": "2022-05-01-preview",
      "name": "[concat(variables('sqlServerName'), '/', variables('databaseName'))]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Sql/servers', variables('sqlServerName'))]"
      ],
      "sku": "[if(variables('isServerless'), createObject('name', 'GP_S_Gen5_1', 'tier', 'GeneralPurpose', 'family', 'Gen5', 'capacity', 1), createObject('name', 'Basic', 'tier', 'Basic', 'capacity', 5))]",
      "properties": "[if(variables('isServerless'), createObject('autoPauseDelay', 60, 'minCapacity', '0.5', 'collation', 'Japanese_CI_AS'), createObject('collation', 'Japanese_CI_AS'))]"
    }
  ],
  "outputs": {
    "webAppName": {
      "type": "string",
      "value": "[variables('webAppName')]"
    },
    "webAppUrl": {
      "type": "string",
      "value": "[variables('webAppUrl')]"
    },
    "sqlServerFqdn": {
      "type": "string",
      "value": "[concat(variables('sqlServerName'), '.database.windows.net')]"
    },
    "resourceGroupName": {
      "type": "string",
      "value": "[resourceGroup().name]"
    }
  }
}
